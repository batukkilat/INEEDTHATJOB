# ── Required ──────────────────────────────────────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# ── LLM models (Groq) ─────────────────────────────────────────────────────────
SCORING_MODEL=llama-3.1-8b-instant
GENERATION_MODEL=llama-3.3-70b-versatile

# ── Scraping ──────────────────────────────────────────────────────────────────
SCRAPE_PLATFORMS=["linkedin", "glints", "jobstreet"]
SCRAPE_MAX_PAGES=5
# Session cookies — grab from browser DevTools after logging in to each site
LINKEDIN_SESSION_COOKIE=
GLINTS_SESSION_COOKIE=
JOBSTREET_SESSION_COOKIE=

# ── Email (SMTP) — configurable from Settings UI, no manual edit needed ───────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=you@gmail.com
FROM_NAME=Your Full Name

# ── Scheduling ────────────────────────────────────────────────────────────────
SCHEDULE_ENABLED=false
SCHEDULE_CRON=0 9 * * 1-5

# ── Server ────────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000

# ── Storage ───────────────────────────────────────────────────────────────────
DB_PATH=./data/ineedthatjob.db
OUTPUT_DIR=./data/output
SCREENSHOT_DIR=./data/screenshots
LOG_DIR=./data/logs
