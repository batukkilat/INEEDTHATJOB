# LLM (Ollama — install from https://ollama.com, then: ollama pull llama3.2:3b)
OLLAMA_BASE_URL=http://127.0.0.1:11434/api
SCORING_MODEL=llama3.2:3b
GENERATION_MODEL=llama3.2:3b

# Scraping
SCRAPE_PLATFORMS=["linkedin", "glints", "jobstreet"]
SCRAPE_MAX_PAGES=5
LINKEDIN_SESSION_COOKIE=
GLINTS_SESSION_COOKIE=
JOBSTREET_SESSION_COOKIE=

# Application
APPLY_DELAY_MIN_SECONDS=60
APPLY_DELAY_MAX_SECONDS=120

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=you@gmail.com
FROM_NAME=Your Full Name

# Scheduling
SCHEDULE_ENABLED=false
SCHEDULE_CRON=0 9 * * 1-5

# Server
HOST=127.0.0.1
PORT=8000

# Storage paths
DB_PATH=./data/ineedthatjob.db
OUTPUT_DIR=./data/output
SCREENSHOT_DIR=./data/screenshots
LOG_DIR=./data/logs
